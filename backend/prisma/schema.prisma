// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// GENERAL
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// TABLES
model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  displayName       String
  passwordHash      String
  creationTimestamp DateTime @default(now())
  lastUpdated       DateTime @updatedAt
  gardens           Garden[] 
}

model Garden {
  id                Int      @id @default(autoincrement())
  ownerId           Int
  owner             User     @relation(fields: [ownerId], references: [id])
  name              String
  description       String
  latitude          Float
  longitude         Float
  timezone          String?
  creationTimestamp DateTime @default(now())
  lastUpdated       DateTime @updatedAt
  plants            PlantInstance[]       
}

model PlantInstance{
  id                Int       @id   @default(autoincrement())
  gardenId          Int
  garden            Garden     @relation(fields: [gardenId], references: [id])
  speciesId         Int
  species           Species    @relation(fields: [speciesId], references: [id])
  soilId            Int    
  soil              Soil       @relation(fields: [soilId], references: [id])
  creationTimestamp DateTime @default(now())
  lastUpdated       DateTime @updatedAt
}

model Species {
  id                Int     @id @default(autoincrement())
  commonName        String  @unique
  scientificName    String  @unique
  growthRate        Float   
  bloomRate         Float?  // optional, how fast it blooms (cm/week or days)
  witherRate        Float?  // optional, rate of decay/dying
  minTemp           Float?  // minimum temperature tolerated (°C)
  maxTemp           Float?  // maximum temperature tolerated (°C)
  minHumidity       Float?  // minimum humidity tolerated (%)
  maxHumidity       Float?  // maximum humidity tolerated (%)
  avgHoursSun       Float?  // average hours of sun/day
  imgSrcUrl         String? // optional, URL of an image
  notes             String? // optional free text
  plantInstances    PlantInstance[] // back-relation to individual plants
}


model Soil{
  id                 Int       @id   @default(autoincrement())
  nitrogen           Float   // typically in percentage or ppm
  phosphorus         Float   // % or ppm
  potassium          Float   // % or ppm
  pH                 Float   // 0–14
  organicPercentage  Float?  // % of organic matter (optional)
  type               SoilType  
  plantInstances     PlantInstance[]
}

// ENUMS
enum SoilType {
  LOAM
  SANDY
  CLAY
  SILT
  PEAT
  CHALK
}
