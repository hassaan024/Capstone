{
  "compilerOptions": {
    "baseUrl": "./src",
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": false,
    // "paths": {
    //   "@generated/*": ["./generated/prisma/*"]
    // }
  },
  "include": [
    "src/**/*", 
    "prisma.config.ts",
    "src/generated/prisma/**/*.ts"
  ]
}
